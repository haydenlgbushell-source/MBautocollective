# Supabase — https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# HubSpot — Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=your_private_app_token

# Next.js
NEXT_PUBLIC_SITE_URL=https://mbautocollective.com

# Microsoft / Outlook Calendar (for Book a Viewing feature)
# Create an Azure app registration → App permissions → Calendars.ReadWrite → Grant admin consent
# https://portal.azure.com → Azure Active Directory → App registrations
MICROSOFT_TENANT_ID=your_tenant_id
MICROSOFT_CLIENT_ID=your_client_id
MICROSOFT_CLIENT_SECRET=your_client_secret
OUTLOOK_CALENDAR_EMAIL=matt@mbautocollective.com
