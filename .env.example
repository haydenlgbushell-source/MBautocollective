# Anthropic — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# EasyCars DMS credentials (used by the auto-scrape feature)
EASYCARS_EMAIL=your@email.com
EASYCARS_PASSWORD=your_password

# Supabase — https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# HubSpot — Settings → Integrations → Private Apps → Auth tab
# Scopes needed: crm.objects.contacts.write, crm.objects.deals.write
HUBSPOT_ACCESS_TOKEN=your_private_app_token

# HubSpot Portal ID — visible in your HubSpot URL: app-ap1.hubspot.com/portal/XXXXXXX
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=442916004

# HubSpot Form GUIDs — Marketing → Forms → (select form) → Actions → Share → Embed Code
# Copy the formId UUID from the embed snippet for each form
NEXT_PUBLIC_HUBSPOT_CONTACT_FORM_ID=your_contact_form_guid
NEXT_PUBLIC_HUBSPOT_ENQUIRY_FORM_ID=your_enquiry_form_guid
NEXT_PUBLIC_HUBSPOT_VALUATION_FORM_ID=your_valuation_form_guid
# Car sourcing uses a custom React form (HubSpot embed doesn't support custom fields)
# Submissions go to HubSpot CRM via the API automatically — no form GUID needed
HUBSPOT_SOURCING_FORM_ID=

# ── WhatsApp AI Agent ──────────────────────────────────────────────────────
#
# Meta Cloud API — https://developers.facebook.com → Your App → WhatsApp → API Setup
# WHATSAPP_TOKEN: the temporary or permanent access token shown on the API Setup page
# WHATSAPP_PHONE_NUMBER_ID: the numeric ID shown next to your test/production number
# WHATSAPP_VERIFY_TOKEN: any string you choose — you'll paste this into the Meta
#   webhook config under Webhooks → Edit → Verify Token
WHATSAPP_TOKEN=your_meta_cloud_api_access_token
WHATSAPP_VERIFY_TOKEN=mbautocollective_webhook_2025
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Next.js
NEXT_PUBLIC_SITE_URL=https://mbautocollective.com

# ── Social Publishing ──────────────────────────────────────────────────────
#
# Facebook & Instagram (both use the same Page Access Token via Meta Graph API)
# 1. Go to developers.facebook.com → Your App → Tools → Graph API Explorer
# 2. Generate a Page Access Token with permissions:
#    pages_manage_posts, pages_read_engagement,
#    instagram_basic, instagram_content_publish
# 3. Convert to long-lived token (60 days) via:
#    GET /oauth/access_token?grant_type=fb_exchange_token&...
# 4. Find your Page ID: Graph API Explorer → /me/accounts
# 5. Find your Instagram Business Account ID:
#    GET /{page-id}?fields=instagram_business_account
FACEBOOK_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# LinkedIn (Company Page)
# 1. Go to linkedin.com/developers → Your App → Auth → OAuth 2.0 tools
# 2. Request an access token with scopes:
#    w_organization_social, r_organization_social
# 3. Find your Organization ID:
#    GET https://api.linkedin.com/v2/organizationalEntityAcls?q=roleAssignee
#    (look for the numeric ID in the organization URN, e.g. urn:li:organization:12345678)
LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth2_access_token
LINKEDIN_ORGANIZATION_ID=your_linkedin_organization_numeric_id
