# Supabase — https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# HubSpot — Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=your_private_app_token

# HubSpot Portal ID — Settings → Account Setup → Account Information → Hub ID
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=your_hub_id

# HubSpot Form GUIDs — Marketing → Forms → (select form) → Actions → Share → Embed Code
# Each value is the UUID shown in the embed snippet (e.g. 12345678-abcd-...)
HUBSPOT_CONTACT_FORM_ID=your_contact_form_guid
HUBSPOT_ENQUIRY_FORM_ID=your_enquiry_form_guid
HUBSPOT_VALUATION_FORM_ID=your_valuation_form_guid

# Next.js
NEXT_PUBLIC_SITE_URL=https://mbautocollective.com
